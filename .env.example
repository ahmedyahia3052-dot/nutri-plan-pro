# ─────────────────────────────────────────────────────────────────────────────
# Nutri Plan Pro – Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# SETUP STEPS:
#   1. Copy this file:  copy .env.example .env        (Windows CMD)
#                       cp .env.example .env           (Mac/Linux/PowerShell)
#   2. Fill in DATABASE_URL and JWT_SECRET below
#   3. Run:  npm run db:push && npm run db:seed
#   4. Run:  npm run dev
# ─────────────────────────────────────────────────────────────────────────────

# ── DATABASE (required) ───────────────────────────────────────────────────────
# PostgreSQL 14+ required. Install from: https://www.postgresql.org/download/
#
# Windows typical:   postgresql://postgres:yourpassword@localhost:5432/nutri_plan_pro
# Mac (Homebrew):    postgresql://postgres@localhost:5432/nutri_plan_pro
# Linux:             postgresql://postgres:yourpassword@localhost:5432/nutri_plan_pro
#
# Create the database first:
#   Windows CMD:  psql -U postgres -c "CREATE DATABASE nutri_plan_pro;"
#   Mac/Linux:    createdb nutri_plan_pro
DATABASE_URL=postgresql://postgres:password@localhost:5432/nutri_plan_pro

# ── JWT SECRET (required) ─────────────────────────────────────────────────────
# Must be a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme_replace_with_64_random_characters_minimum

# ── SERVER PORT (optional) ────────────────────────────────────────────────────
# The API server port. Vite dev server proxies /api requests to this port.
# Change if 3001 is already in use on your machine.
PORT=3001

# ─────────────────────────────────────────────────────────────────────────────
# TROUBLESHOOTING
# ─────────────────────────────────────────────────────────────────────────────
# "Cannot find module @rollup/rollup-linux-x64-gnu"
#   → Run: npm run clean-install
#
# "connect ECONNREFUSED 127.0.0.1:5432"
#   → PostgreSQL is not running. Start it from Services (Windows) or:
#     Mac:   brew services start postgresql
#     Linux: sudo systemctl start postgresql
#
# "relation does not exist"
#   → Run: npm run db:push && npm run db:seed
#
# "Missing .env variables"
#   → This file was not copied to .env, or DATABASE_URL/JWT_SECRET are not set
# ─────────────────────────────────────────────────────────────────────────────
