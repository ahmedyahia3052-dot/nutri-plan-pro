{
  "name": "nutri-plan-pro",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node dist/server/index.js",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx server/db/seed.ts",
    "check-env": "node -e \"const r=['DATABASE_URL','JWT_SECRET'],m=r.filter(k=>!process.env[k]);if(m.length){console.error('\\n  Missing .env variables: '+m.join(', ')+'\\n  Copy .env.example to .env and fill in the values.\\n');process.exit(1)}console.log('  Environment OK')\"",
    "clean": "node -e \"const fs=require('fs');['node_modules','package-lock.json'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}})\" && npm install",
    "clean-install": "node -e \"const fs=require('fs');console.log('Removing node_modules and lockfile...');['node_modules','package-lock.json'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true});console.log('  Removed: '+p)}catch(e){}});console.log('Running npm install...')\" && npm install"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cors": "2.8.6",
    "dotenv": "16.6.1",
    "drizzle-orm": "0.38.4",
    "express": "4.22.1",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsonwebtoken": "9.0.3",
    "pg": "8.20.0",
    "react-i18next": "^17.0.6"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tailwindcss/typography": "0.5.19",
    "@tanstack/react-query": "5.100.8",
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.19",
    "@types/express": "4.17.25",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "22.19.17",
    "@types/pg": "8.20.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "10.5.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "concurrently": "9.2.1",
    "drizzle-kit": "0.29.1",
    "drizzle-zod": "0.5.1",
    "lucide-react": "0.468.0",
    "postcss": "8.5.13",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "2.15.4",
    "tailwind-merge": "2.6.1",
    "tailwindcss": "3.4.19",
    "tailwindcss-animate": "1.0.7",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "5.4.21",
    "wouter": "3.9.0",
    "zod": "3.25.76"
  }
}
