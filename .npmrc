# Suppress funding and audit prompts for a cleaner install experience
fund=false
audit=false

# NOTE: This project uses Tailwind CSS v3 which has NO native bindings.
# The @tailwindcss/oxide issue only affects Tailwind v4 — we are pinned to v3.4.19.
# Do NOT add "omit=optional" here — it would break Rollup's platform-specific bindings.
